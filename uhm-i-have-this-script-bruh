local function C79ae0d95b56d4d24aa1ac8d55f576f6()
local script = Instance.new("LocalScript", boton TP_1)
local boton = script.Parent
local player = game.Players.LocalPlayer
local mouse = player:GetMouse()

local tpMode = false

local function getCharacter()
	local char = player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	return char, hrp
end

local clickConnection

local function enableTP()
	tpMode = true

	clickConnection = mouse.Button1Down:Connect(function()
		if not tpMode then return end

		local _, hrp = getCharacter()
		if not hrp then return end

		local target = mouse.Hit
		if target then
			hrp.CFrame = CFrame.new(target.Position + Vector3.new(0, 3, 0))
		end
	end)
end

local function disableTP()
	tpMode = false
	if clickConnection then
		clickConnection:Disconnect()
		clickConnection = nil
	end
end

boton.MouseButton1Click:Connect(function()
	if tpMode then
		disableTP()
	else
		enableTP()
	end
end)

player.CharacterAdded:Connect(function()
	disableTP()
end)
end

coroutine.wrap(C79ae0d95b56d4d24aa1ac8d55f576f6)()

local function C5770a45797cf4107b448397356b0787()
local script = Instance.new("LocalScript", boton dance_1)
local boton = script.Parent
local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")

local IDLE_ANIM = "rbxassetid://118856351023466"
local RUN_ANIM = "rbxassetid://80815742707964"

local enabled = false
local track

local currentAnim = nil

local function getHumanoid()
	local char = player.Character
	if not char then return end
	return char:FindFirstChildOfClass("Humanoid"), char:FindFirstChild("HumanoidRootPart")
end

local function stopAnim()
	if track then
		track:Stop()
		track:Destroy()
		track = nil
	end
	currentAnim = nil
end

local function playAnim(id, humanoid)
	if currentAnim == id then return end

	stopAnim()

	local animator = humanoid:FindFirstChildOfClass("Animator")
	if not animator then
		animator = Instance.new("Animator")
		animator.Parent = humanoid
	end

	local anim = Instance.new("Animation")
	anim.AnimationId = id

	track = animator:LoadAnimation(anim)
	track.Priority = Enum.AnimationPriority.Action
	track.Looped = true
	track:Play()

	currentAnim = id
end

local function startLoop()
	runService.RenderStepped:Connect(function()
		if not enabled then return end

		local humanoid, hrp = getHumanoid()
		if not humanoid or not hrp then return end

		local moving = humanoid.MoveDirection.Magnitude > 0.1

		if moving then
			playAnim(RUN_ANIM, humanoid)
		else
			playAnim(IDLE_ANIM, humanoid)
		end
	end)
end

boton.MouseButton1Click:Connect(function()
	enabled = not enabled

	if not enabled then
		stopAnim()
	else
		local humanoid = getHumanoid()
		if humanoid then
			startLoop()
		end
	end
end)

player.CharacterAdded:Connect(function()
	enabled = false
	stopAnim()
end)
end

coroutine.wrap(C5770a45797cf4107b448397356b0787)()

