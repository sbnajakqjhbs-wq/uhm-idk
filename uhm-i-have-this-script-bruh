local function C8d58d28532db4858ac00fb9711114bf()
local script = Instance.new("LocalScript", boton fly_1)
local boton = script.Parent
local player = game.Players.LocalPlayer
local userInput = game:GetService("UserInputService")
local runService = game:GetService("RunService")

local flying = false
local speed = 60

local velocity
local gyro
local loopConnection

local keys = {
	W = false,
	A = false,
	S = false,
	D = false,
	Up = false,
	Down = false
}

local function getCharParts()
	local char = player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	return char, hrp
end

local function stopFly()
	flying = false

	if loopConnection then
		loopConnection:Disconnect()
		loopConnection = nil
	end

	if velocity then velocity:Destroy() end
	if gyro then gyro:Destroy() end
end

local function startFly()
	local char, hrp = getCharParts()
	if not hrp then return end

	flying = true

	velocity = Instance.new("BodyVelocity")
	velocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
	velocity.Parent = hrp

	gyro = Instance.new("BodyGyro")
	gyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
	gyro.CFrame = hrp.CFrame
	gyro.Parent = hrp

	loopConnection = runService.RenderStepped:Connect(function()
		if not flying then return end
		local _, hrp = getCharParts()
		if not hrp then return end

		local cam = workspace.CurrentCamera
		local move = Vector3.zero

		if keys.W then move += cam.CFrame.LookVector end
		if keys.S then move -= cam.CFrame.LookVector end
		if keys.A then move -= cam.CFrame.RightVector end
		if keys.D then move += cam.CFrame.RightVector end
		if keys.Up then move += Vector3.new(0, 1, 0) end
		if keys.Down then move -= Vector3.new(0, 1, 0) end

		if move.Magnitude > 0 then
			velocity.Velocity = move.Unit * speed
		else
			velocity.Velocity = Vector3.zero
		end

		gyro.CFrame = cam.CFrame
	end)
end

boton.MouseButton1Click:Connect(function()
	if flying then
		stopFly()
	else
		startFly()
	end
end)

userInput.InputBegan:Connect(function(input, processed)
	if processed then return end

	if input.KeyCode == Enum.KeyCode.W then keys.W = true end
	if input.KeyCode == Enum.KeyCode.A then keys.A = true end
	if input.KeyCode == Enum.KeyCode.S then keys.S = true end
	if input.KeyCode == Enum.KeyCode.D then keys.D = true end
	if input.KeyCode == Enum.KeyCode.Space then keys.Up = true end
	if input.KeyCode == Enum.KeyCode.LeftShift then keys.Down = true end
end)

userInput.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.W then keys.W = false end
	if input.KeyCode == Enum.KeyCode.A then keys.A = false end
	if input.KeyCode == Enum.KeyCode.S then keys.S = false end
	if input.KeyCode == Enum.KeyCode.D then keys.D = false end
	if input.KeyCode == Enum.KeyCode.Space then keys.Up = false end
	if input.KeyCode == Enum.KeyCode.LeftShift then keys.Down = false end
end)
end

coroutine.wrap(C8d58d28532db4858ac00fb9711114bf)()

