local function C8eaaf00d3dc74c9f96f6c405b23e0cb()
local script = Instance.new("LocalScript", mas_1)
local Players = game:GetService("Players")

local frame = script.Parent
local list = frame:WaitForChild("PlayerList")
local layout = list:WaitForChild("UIListLayout")
local banButton = frame:WaitForChild("boton de ban")

list.Visible = true
list.ScrollBarThickness = 6
list.AutomaticCanvasSize = Enum.AutomaticSize.Y

local selectedPlayer
local selectedButton

local function clear()
	for _, v in ipairs(list:GetChildren()) do
		if v:IsA("TextButton") then
			v:Destroy()
		end
	end
end

local function createPlayer(p)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -10, 0, 30)
	btn.BackgroundColor3 = Color3.fromRGB(60,60,60)
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Text = p.Name
	btn.Parent = list

	btn.MouseButton1Click:Connect(function()
		if selectedButton then
			selectedButton.BackgroundColor3 = Color3.fromRGB(60,60,60)
		end

		selectedPlayer = p
		selectedButton = btn
		btn.BackgroundColor3 = Color3.fromRGB(200,50,50)
	end)
end

local function refresh()
	clear()

	for _, p in ipairs(Players:GetPlayers()) do
		createPlayer(p)
	end

	task.wait()
	list.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
end

Players.PlayerAdded:Connect(refresh)
Players.PlayerRemoving:Connect(refresh)

refresh()

banButton.MouseButton1Click:Connect(function()
	if not selectedPlayer then return end

	print("BAN:", selectedPlayer.Name)

	if selectedPlayer.Character then
		selectedPlayer.Character:BreakJoints()
	end

	if selectedButton then
		selectedButton:Destroy()
	end

	selectedPlayer = nil
	selectedButton = nil
end)
end

coroutine.wrap(C8eaaf00d3dc74c9f96f6c405b23e0cb)()
